<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="ChessApp.GameWindow"
        CanResize="False" Height="600" Width="558"
        Title="ChessApp">
    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
            <GradientStop Color="#202020" Offset="0" />
            <GradientStop Color="#252525" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <StackPanel>
        <Label FontFamily="Lucida Console" Name="Title" FontWeight="Bold" FontSize="24" Margin="48, 20, 48, 7" Foreground="White">Chess</Label>
        <Border CornerRadius="5" BorderBrush="#363636" Background="#363636" Margin="50, 0" BorderThickness="2">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Width="408">
                    <Label FontFamily="Lucida Console" Margin="4, 0" FontWeight="Bold" FontSize="18"  Foreground="White">Bot</Label>
                    <Label Name="BotTimerLabel" FontFamily="Lucida Console" Margin="302, 0"  FontWeight="Bold" FontSize="18" HorizontalAlignment="Right" Foreground="White">10:00</Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#252525" CornerRadius="2" BorderThickness="0">
                        <StackPanel Width="25" Height="400">
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♔</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♕</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♗</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♗</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♘</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♘</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♖</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♖</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♙</Label>
                    </StackPanel>
                    </Border>
                    <WrapPanel Name="CellsWrap" Width="400" Height="400" Margin="2,0"></WrapPanel>
                    <Border Background="#252525" CornerRadius="2" BorderThickness="0">
                        <StackPanel Width="25" Height="400">
                         <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♚</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♛</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♝</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♝</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♞</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♞</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♜</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♜</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                        <Label Width="25" Height="25" Foreground="#565656" FontSize="20" HorizontalAlignment="Center">♟</Label>
                    </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Width="408">
                    <Label FontFamily="Lucida Console" Margin="4, 0" FontWeight="Bold" FontSize="18"  Foreground="White">You</Label>
                    <Label Name="PlayerTimerLabel" FontFamily="Lucida Console" Margin="302, 0"  FontWeight="Bold" FontSize="18" HorizontalAlignment="Right" Foreground="White">10:00</Label>
                </StackPanel>
            </StackPanel>
        </Border>
        <Button FontFamily="Lucida Console" Background="#ff0040" FontSize="16"  Click="Button_OnClick" HorizontalAlignment="Right" Margin="50, 7, 50, 20" Foreground="White">Leave</Button>
    </StackPanel>
</Window>
