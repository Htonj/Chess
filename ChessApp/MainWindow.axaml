<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="ChessApp.MainWindow"
        CanResize="False" Height="368" Width="600"
        Title="ChessApp">
    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
            <GradientStop Color="#202020" Offset="0" />
            <GradientStop Color="#252525" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <StackPanel Margin="50, 40" >
        <Label FontFamily="Lucida Console" FontSize="24" Foreground="White" FontWeight="Bold">There are two (actually one) ways...</Label>
        <StackPanel Orientation="Horizontal">
            <Button FontFamily="Lucida Console" Click="BotGameButton_OnClick" Background="#323232" Width="240" Height="240" FontSize="13" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" Foreground="Crimson">Play with a bot (Does not working)</Button>
            <Button FontFamily="Lucida Console" Click="LocalGameButton_OnClick" Background="#323232" Width="240" Height="240" FontSize="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" Foreground="White">Play local</Button>
        </StackPanel>
    </StackPanel>
</Window>
