<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="ChessApp.LocalGameWindow"
        CanResize="False" Height="600" Width="558"
        Title="Local chess game">
    <Window.Background>
        <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
            <GradientStop Color="#202020" Offset="0" />
            <GradientStop Color="#252525" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>
    <StackPanel>
        <Label FontFamily="Lucida Console" Name="Title" FontWeight="Bold" FontSize="24" Margin="48, 20, 48, 7" Foreground="White">Chess</Label>
        <Border CornerRadius="5" BorderBrush="#363636" Background="#363636" Margin="50, 0" BorderThickness="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Width="408">
                    <Label FontFamily="Lucida Console" Margin="4, 0" FontWeight="Bold" FontSize="18"  Foreground="White">Player 2</Label>
                    <Label Name="Player2TimerLabel" FontFamily="Lucida Console" Margin="259, 0"  FontWeight="Bold" FontSize="18" HorizontalAlignment="Right" Foreground="White">10:00</Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#252525" CornerRadius="2" Margin="2,0" BorderThickness="0">
                        <StackPanel Width="25" Height="400" Name="deadfigbstack"></StackPanel>
                    </Border>
                    <WrapPanel Name="CellsWrap" Width="400" Height="400"></WrapPanel>
                    <Border Background="#252525" CornerRadius="2" Margin="2,0" BorderThickness="0">
                        <StackPanel Width="25" Height="400" Name="deadfigwstack"></StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Width="408">
                    <Label FontFamily="Lucida Console" Margin="4, 0" FontWeight="Bold" FontSize="18"  Foreground="White">Player 1</Label>
                    <Label Name="Player1TimerLabel" FontFamily="Lucida Console" Margin="259, 0"  FontWeight="Bold" FontSize="18" HorizontalAlignment="Right" Foreground="White">10:00</Label>
                </StackPanel>
            </StackPanel>
        </Border>
        <Grid Margin="50, 7, 50, 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Name="NotifyLabel" Foreground="Crimson" FontFamily="Lucida Console"></Label>
            <Button Grid.Column="1" FontFamily="Lucida Console" Background="#ff0040" FontSize="16"  Click="LeaveButton_OnClick" HorizontalAlignment="Right" Foreground="White">Leave</Button>
        </Grid>
    </StackPanel>
</Window>
